#!/usr/bin/env bash
# dev-team post-commit hook
# Reads the commit message and bumps plugin.json version based on
# Conventional Commits, then amends the commit to include the bump.
#
# Convention:
#   feat!: or BREAKING CHANGE → major bump
#   feat:                      → minor bump
#   fix: docs: chore: refactor: etc. → patch bump
#   No prefix or non-plugin files only → no bump
#
# Install: git config core.hooksPath .githooks

set -euo pipefail

[ -f plugin.json ] || exit 0

# Prevent infinite loop (amend triggers post-commit again)
if [ "${DEVTEAM_BUMPING:-}" = "1" ]; then
  exit 0
fi

# Check if any plugin content changed in the last commit
changed_files=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null || true)
plugin_changed=false

for sf in $changed_files; do
  case "$sf" in
    agents/*|protocols/*|skills/*|.githooks/*) plugin_changed=true ;;
  esac
done

[ "$plugin_changed" = true ] || exit 0

# Read commit message
commit_msg=$(git log -1 --format='%B')

# Determine bump type
bump="none"

if echo "$commit_msg" | head -1 | grep -qE '^[a-z]+!(\(.+\))?:'; then
  bump="major"
elif echo "$commit_msg" | grep -q 'BREAKING CHANGE'; then
  bump="major"
elif echo "$commit_msg" | head -1 | grep -qE '^feat(\(.+\))?:'; then
  bump="minor"
elif echo "$commit_msg" | head -1 | grep -qE '^(fix|docs|chore|refactor|style|perf|test|ci|build)(\(.+\))?:'; then
  bump="patch"
fi

[ "$bump" != "none" ] || exit 0

# Read current version
current_version=$(python3 -c "import json; print(json.load(open('plugin.json'))['version'])" 2>/dev/null || echo "0.0.0")
IFS='.' read -r major minor patch <<< "$current_version"

case "$bump" in
  major) new_version="$((major + 1)).0.0" ;;
  minor) new_version="$major.$((minor + 1)).0" ;;
  patch) new_version="$major.$minor.$((patch + 1))" ;;
esac

# Update plugin.json
python3 -c "
import json
d = json.load(open('plugin.json'))
d['version'] = '$new_version'
with open('plugin.json', 'w') as f:
    json.dump(d, f, indent=2)
    f.write('\n')
"

# Amend the commit to include the version bump
export DEVTEAM_BUMPING=1
git add plugin.json
git commit --amend --no-edit --no-verify
unset DEVTEAM_BUMPING

echo "📦 Version: $current_version → $new_version ($bump)"
